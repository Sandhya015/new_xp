{
  "name": "xpertintern-api",
  "version": "0.1.0",
  "private": true,
  "description": "Serverless deploy for XpertIntern Flask API (Lambda + API Gateway)",
  "scripts": {
    "deploy:dev": "serverless deploy --stage dev",
    "deploy:staging": "serverless deploy --stage staging",
    "deploy:production": "serverless deploy --stage production",
    "invoke:local": "serverless invoke local -f api --path event.json",
    "logs": "serverless logs -f api -t"
  },
  "devDependencies": {
    "serverless": "^3.38.0",
    "serverless-wsgi": "^3.0.0",
    "serverless-python-requirements": "^6.1.0"
  }
}

# Copy to .env and fill in. Never commit .env to git.

# MongoDB Atlas connection (replace <password> with your DB user password)
MONGODB_URI=mongodb+srv://xpertintern_app:<password>@cluster0.xxxxx.mongodb.net/xpertintern?retryWrites=true&w=majority

# Or use MONGO_URI (same value)
# MONGO_URI=mongodb+srv://...

# Secret for session/JWT (generate a random string for production)
SECRET_KEY=your-secret-key-change-in-production
# JWT_SECRET_KEY=optional-override-for-jwt

# CORS: comma-separated origins that can call the API (frontend URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: Flask env (development | staging | production)
# FLASK_ENV=development

# Backend — copy to .env and set per environment
FLASK_ENV=development
SECRET_KEY=change-me-in-production
# CORS (comma-separated origins, or * for dev)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Database (when MongoDB is connected)
# MONGODB_URI=mongodb://localhost:27017/xpertintern
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/xpertintern
# Razorpay (when integrated)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

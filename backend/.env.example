# Copy to .env and fill in. Never commit .env to git.

# MongoDB Atlas (replace <db_password> with your Atlas DB user password)
# Cluster: cluster0.yhkeqow.mongodb.net — user: xpertintern_app
MONGODB_URI=mongodb+srv://xpertintern_app:<db_password>@cluster0.yhkeqow.mongodb.net/xpertintern?retryWrites=true&w=majority&appName=Cluster0

# Or use MONGO_URI (same value)
# MONGO_URI=mongodb+srv://...

# Secret for session/JWT (generate a random string for production)
SECRET_KEY=your-secret-key-change-in-production
# JWT_SECRET_KEY=optional-override-for-jwt

# CORS: comma-separated origins that can call the API (frontend URL)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Razorpay — Dashboard → Settings → API Keys (Test mode for local dev)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Zoho SMTP (welcome / enrollment / certificate emails). Omit to skip sending mail locally.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=admin@xpertintern.com
# Double quotes required if password contains # (otherwise .env treats # as comment)
SMTP_PASSWORD="your-zoho-app-password"
MAIL_FROM=admin@xpertintern.com
MAIL_FROM_NAME=XpertIntern

# If 587 fails, try Zoho SSL: SMTP_PORT=465 and SMTP_USE_SSL=1
# India-hosted mailboxes sometimes use SMTP_HOST=smtp.zoho.in

# Force send mail in the HTTP thread (debugging only; register/pay may feel slower)
# EMAIL_SEND_SYNC=1

# Local Flask (optional; default 5000)
# PORT=5000

# Use development locally so DEBUG and dev CORS defaults apply
FLASK_ENV=development

# --- Deploy (Lambda): set the same keys in CI or `serverless deploy` environment;
# never commit real values. See backend/serverless.yml provider.environment.

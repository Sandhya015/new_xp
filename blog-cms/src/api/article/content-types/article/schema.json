{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Blog posts (XpertIntern)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "description": {
      "type": "richtext",
      "required": true
    },
    "coverImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Internships",
        "Career Tips",
        "Training",
        "Industry News",
        "Student Success"
      ],
      "default": "Career Tips"
    },
    "readTime": {
      "type": "integer",
      "default": 5,
      "min": 1
    },
    "publishedDate": {
      "type": "date"
    }
  }
}

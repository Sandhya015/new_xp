HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# --- Database
# Local dev (default): sqlite — leave DATABASE_CLIENT unset or set sqlite.
# DATABASE_CLIENT=sqlite

# Production (Render Postgres, etc.):
# DATABASE_CLIENT=postgres
# Single URL (recommended). On Render, link the DB or paste Internal Database URL for the web service.
# Append ?sslmode=require for external hostname (e.g. *.render.com).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# DATABASE_SSL=true
# If TLS verification fails with your provider, only then try:
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

# --- Public URL (HTTPS admin + media URLs)
# Set to your real API origin. On Render, PUBLIC_URL is optional if you set nothing — server.ts also reads RENDER_EXTERNAL_URL when present.
# PUBLIC_URL=https://your-strapi-service.onrender.com
# Also adds that origin to CORS (admin / tools calling the API with this Origin).
# RENDER_EXTERNAL_URL is used on Render if PUBLIC_URL is unset.

# --- CORS (optional extras)
# config/middlewares.ts always allows: localhost:5173, www.xpertintern.com, xpertintern.com
# Add more (comma-separated), e.g. Vercel preview/production URL:
# CORS_ORIGIN=https://your-app.vercel.app,https://your-app-git-main-xxx.vercel.app

# --- Media uploads (~50 MB; see plugins.ts + strapi::body)
# Strapi stores metadata in Postgres; file bytes are either local files or S3 objects.
#
# Recommended on Render without a paid disk: AWS S3 (official provider). Set all three; Strapi switches to S3.
# Cost is usually very low for blog-sized images (storage + modest egress). Use a dedicated IAM user + bucket.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=ap-south-1
# Optional: CloudFront or static URL so browsers load from a stable host:
# AWS_S3_PUBLIC_URL=https://your-bucket.s3.ap-south-1.amazonaws.com
#
# Local-only (ephemeral on Render unless you add a disk): omit AWS_* above.
# Optional Docker: UPLOADS_PERSIST_PATH + mounted folder (see scripts/docker-entrypoint.sh).
# Render disk mount path (if paid): /opt/app/public/uploads

# Frontend — copy to .env for local dev (optional)
# When you run the app on localhost/127.0.0.1, the app automatically uses http://localhost:5000
# so you don't need to set VITE_API_URL for local testing. Set it only if you want to override.
# Local backend (default when on localhost):
# VITE_API_URL=http://localhost:5000
# Production (set in Amplify/hosting env vars before build):
# VITE_API_URL=https://kbp3dx8ic4.execute-api.ap-south-1.amazonaws.com/dev
